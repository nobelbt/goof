  return (
    <section style={styles.hero}>
      <div style={styles.heroInner}>
        <div style={styles.heroMarkWrap}>
          <div
            style={{
              transition: "transform 1.1s cubic-bezier(.16,1,.3,1)",
              transform: formed ? "rotate(0deg) scale(1)" : "rotate(-18deg) scale(0.92)",
            }}
          >
            <PetalMark size={120} scattered={!formed} />
          </div>
        </div>
        <p style={styles.heroEyebrow}>WEB STUDIO FOR LOCAL BUSINESS</p>
        <h1 style={styles.heroTitle}>
          Every business starts <span style={styles.heroTitleMuted}>scattered.</span>
