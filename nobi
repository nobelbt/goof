/* ---------- Petal mark (logo-derived geometry) ---------- */
function PetalMark({ size = 64, scattered = false, className = "" }) {
  // 8 petals at 45deg increments, alternating two gray tones, plus dark center star
  const petals = Array.from({ length: 8 });
  return (
    <svg
      viewBox="0 0 200 200"
      width={size}
      height={size}
      className={className}
      style={{ overflow: "visible" }}
    >
      <g style={{ transformOrigin: "100px 100px" }}>
        {petals.map((_, i) => {
          const angle = i * 45;
          const dark = i % 2 === 0;
          const offset = scattered ? (i % 2 === 0 ? 14 : -10) : 0;
          const rot = scattered ? angle + (i % 2 === 0 ? 6 : -6) : angle;
          return (
            <path
              key={i}
              d="M100 100 C 80 60, 85 20, 100 5 C 115 20, 120 60, 100 100 Z"
              fill={dark ? "#5A5A5A" : "#8C8C8C"}
              transform={`rotate(${rot} 100 100) translate(0 ${offset})`}
              opacity={scattered ? 0.85 : 1}
            />
          );
        })}
        <path
          d="M100 70 L110 85 L128 80 L118 96 L132 108 L113 110 L116 129 L100 117 L84 129 L87 110 L68 108 L82 96 L72 80 L90 85 Z"
          fill="#1A1A1A"
        />
      </g>
    </svg>
  );
}

/* ---------- Hero: petals animate from scattered to formed ---------- */
